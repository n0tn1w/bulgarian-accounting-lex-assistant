# Copy to .env and adjust. All values have sane defaults (see app/core/config.py).
APP_NAME="Accounting AI Assistant"
LOG_LEVEL=INFO

# OCR
OCR_LANGUAGES=bul+eng
OCR_DPI=300

# Comparison (TF-IDF fusion)
IR_WEIGHT_WORD=0.65
IR_WEIGHT_CHAR=0.35
IR_DUPLICATE_THRESHOLD=0.85
IR_MATCH_THRESHOLD=0.10

# Validation
VALIDATION_AMOUNT_TOLERANCE=0.02
VALIDATION_VALID_VAT_RATES=[0,0.09,0.20]

# Database (Postgres + pgvector, see infra/docker-compose.yml)
# Admin role runs DDL/bootstrap; app role (NOSUPERUSER) runs requests under RLS.
DATABASE_ADMIN_URL=postgresql+psycopg://ledgerly:ledgerly@localhost:5432/ledgerly
DATABASE_URL=postgresql+psycopg://ledgerly_app:ledgerly_app@localhost:5432/ledgerly
APP_DB_PASSWORD=ledgerly_app

# Auth
JWT_SECRET=dev-secret-change-me

# LLM for the chat orchestrator (empty = deterministic echo fallback)
# Local Ollama:
#   LLM_MODEL=ollama/mistral
#   LLM_API_BASE=http://localhost:11434
# Cloud (set the matching provider key in the environment):
#   LLM_MODEL=claude-3-5-sonnet-latest      # ANTHROPIC_API_KEY
#   LLM_MODEL=gpt-4o-mini                    # OPENAI_API_KEY
LLM_MODEL=
LLM_API_BASE=
